#!/bin/bash

# run-workflow - Trigger a GitHub Actions workflow and wait for it
#
# Exits 0 if the workflow succeeds, non-zero otherwise.
#
# Requires: gh CLI authenticated with actions:write on the target repo
#
# Usage: run-workflow <org/repo> <workflow>

set -euo pipefail

if [[ $# -ne 2 ]]; then
  echo "Usage: run-workflow <org/repo> <workflow>" >&2
  exit 1
fi

repo="$1"
workflow="$2"

echo "Dispatching ${workflow} workflow on ${repo}..."
gh workflow run "${workflow}" --repo "${repo}"

echo "Waiting for run to appear..."
sleep 3
run_id=$(gh run list --repo "${repo}" --workflow "${workflow}" --limit 1 --json databaseId --jq '.[0].databaseId')

echo "Watching run ${run_id}..."
gh run watch "${run_id}" --repo "${repo}" --exit-status
