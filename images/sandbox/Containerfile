# Containerfile — base sandbox image for fullsend agent execution.
#
# Pre-installs all runtime dependencies needed by any fullsend agent:
#   - Claude Code (official installer)
#   - rsync (for safe repo write-back)
#   - gitleaks (secret scanner, SHA256-verified)
#   - pre-commit + gitlint (repo hook runner + commit message validator)
#   - tirith (Rust CLI for terminal security scanning hooks)
#   - ONNX Runtime + ProtectAI DeBERTa-v3 model for prompt injection
#     detection (loaded natively by fullsend via Go/hugot — no Python
#     runtime dependency, no cold-start latency)
#
# Must extend the OpenShell base image — the sandbox supervisor is
# side-loaded at runtime.
#
# Build:
#   podman build -t <registry>/fullsend-sandbox:v1 \
#     -f images/sandbox/Containerfile images/sandbox/
#
# Per-org images that need extra tools (e.g. Go, Rust) should extend
# this base:
#   FROM <registry>/fullsend-sandbox:v1
#   RUN apt-get install -y golang

FROM ghcr.io/nvidia/openshell-community/sandboxes/base@sha256:f0d1ec92bf219759c1e863c0fa6b1f432ec827331e79ab9e31dab91a3b86b413

# The base image runs as the sandbox user (998). Switch to root for
# package installation and switch back at the end.
USER root

# ---------------------------------------------------------------------------
# Install rsync (for safe repo write-back).
RUN apt-get update \
    && apt-get install -y --no-install-recommends rsync \
    && rm -rf /var/lib/apt/lists/*

# ---------------------------------------------------------------------------
# Install Claude Code (official installer handles Node.js dependency).
RUN curl -fsSL https://claude.ai/install.sh | bash

# ---------------------------------------------------------------------------
# ONNX Runtime + ProtectAI DeBERTa-v3 model for ML-based prompt injection
# scanning. The fullsend binary loads the model directly via Go (hugot +
# onnxruntime) — no Python, no cold-start latency.
#
# HF_HOME must point outside /root/ so the sandbox user (uid 998) can
# read the cached model at runtime — /root/ is mode 700.
ENV HF_HOME="/opt/huggingface" \
    HF_HUB_OFFLINE="1"

# Download ProtectAI DeBERTa-v3 ONNX model files. Uses Python + huggingface_hub
# for the download, then removes huggingface_hub (Python itself stays for
# pre-commit/gitlint). The model files are loaded at runtime by Go/onnxruntime.
ARG PROTECTAI_MODEL_REV=e6535ca4ce3ba852083e75ec585d7c8aeb4be4c5
RUN apt-get update \
    && apt-get install -y --no-install-recommends python3 python3-pip \
    && rm -rf /var/lib/apt/lists/* \
    && /usr/bin/python3 -m pip install --no-cache-dir --break-system-packages \
        "huggingface_hub==0.30.2" \
    && HF_HUB_OFFLINE=0 /usr/bin/python3 -c "\
import json, pathlib; \
from huggingface_hub import hf_hub_download; \
for f in ['onnx/model.onnx', 'onnx/config.json', 'onnx/tokenizer.json', 'onnx/special_tokens_map.json', 'onnx/tokenizer_config.json']: \
    hf_hub_download('protectai/deberta-v3-base-prompt-injection-v2', f, revision='${PROTECTAI_MODEL_REV}'); \
cfg = json.loads(pathlib.Path(hf_hub_download('protectai/deberta-v3-base-prompt-injection-v2', 'onnx/config.json', revision='${PROTECTAI_MODEL_REV}')).read_text()); \
assert cfg.get('id2label', {}).get('1') == 'INJECTION', f\"label ordering mismatch: id2label={cfg.get('id2label')}\"" \
    && echo "ProtectAI DeBERTa-v3 model pre-downloaded at rev ${PROTECTAI_MODEL_REV} (label ordering verified)" \
    && /usr/bin/python3 -m pip uninstall -y huggingface_hub \
    && rm -rf /var/lib/apt/lists/*

# ---------------------------------------------------------------------------
# ONNX Runtime shared library — loaded by hugot at runtime.
# Pinned version for supply chain safety.
# To update: bump ORT_VERSION from:
#   https://github.com/microsoft/onnxruntime/releases
ARG ORT_VERSION=1.24.1
RUN curl -fsSL \
      "https://github.com/microsoft/onnxruntime/releases/download/v${ORT_VERSION}/onnxruntime-linux-x64-${ORT_VERSION}.tgz" \
      -o /tmp/ort.tgz \
    && tar xzf /tmp/ort.tgz -C /tmp/ \
    && cp "/tmp/onnxruntime-linux-x64-${ORT_VERSION}/lib/libonnxruntime.so.${ORT_VERSION}" /usr/lib/ \
    && ln -sf "/usr/lib/libonnxruntime.so.${ORT_VERSION}" /usr/lib/libonnxruntime.so \
    && ldconfig \
    && rm -rf /tmp/ort.tgz "/tmp/onnxruntime-linux-x64-${ORT_VERSION}"

# ---------------------------------------------------------------------------
# gitleaks — secret scanner used by scan-secrets and post-scripts.
# Pinned version + SHA256 checksum for supply chain safety.
# To update: bump version and checksum from:
#   https://github.com/gitleaks/gitleaks/releases/download/v<VERSION>/gitleaks_<VERSION>_checksums.txt
ARG GITLEAKS_VERSION=8.30.1
ARG GITLEAKS_SHA256=551f6fc83ea457d62a0d98237cbad105af8d557003051f41f3e7ca7b3f2470eb
RUN curl -fsSL \
      "https://github.com/gitleaks/gitleaks/releases/download/v${GITLEAKS_VERSION}/gitleaks_${GITLEAKS_VERSION}_linux_x64.tar.gz" \
      -o /tmp/gitleaks.tar.gz \
    && echo "${GITLEAKS_SHA256}  /tmp/gitleaks.tar.gz" | sha256sum -c - \
    && tar xzf /tmp/gitleaks.tar.gz -C /usr/local/bin gitleaks \
    && chmod +x /usr/local/bin/gitleaks \
    && rm /tmp/gitleaks.tar.gz

# ---------------------------------------------------------------------------
# pre-commit + gitlint — pre-commit runs repo-defined hooks (formatting,
# linting, etc.) on changed files. gitlint validates commit message format.
# Baking them in avoids pip installs on every run and ensures availability
# even if pip is network-restricted inside the sandbox.
ARG PRECOMMIT_VERSION=4.5.1
ARG GITLINT_VERSION=0.19.1
RUN /usr/bin/python3 -m pip install --no-cache-dir --break-system-packages \
      "pre-commit==${PRECOMMIT_VERSION}" \
      "gitlint-core==${GITLINT_VERSION}"
RUN for bin in pre-commit gitlint; do \
      if [ -x "/sandbox/.venv/bin/$bin" ]; then \
        ln -sf "/sandbox/.venv/bin/$bin" "/usr/local/bin/$bin"; \
      fi; \
    done

# ---------------------------------------------------------------------------
# tirith — terminal security scanner for PreToolUse hooks.
# Pinned version + sha256 checksum for supply chain safety.
# To update: bump TIRITH_VERSION and TIRITH_SHA256 from the checksums.txt
# in the GitHub release: https://github.com/sheeki03/tirith/releases
ARG TIRITH_VERSION=0.2.12
ARG TIRITH_SHA256=0ecc5430d9d9a78f4df95e14c920897b7ceda1c7102ac132bf6063440e92ef96
RUN curl -fsSL "https://github.com/sheeki03/tirith/releases/download/v${TIRITH_VERSION}/tirith-x86_64-unknown-linux-gnu.tar.gz" \
      -o /tmp/tirith.tar.gz \
    && echo "${TIRITH_SHA256}  /tmp/tirith.tar.gz" | sha256sum -c - \
    && tar xzf /tmp/tirith.tar.gz -C /usr/local/bin tirith \
    && chmod +x /usr/local/bin/tirith \
    && rm /tmp/tirith.tar.gz

# ---------------------------------------------------------------------------
# Workaround for NVIDIA/OpenShell#886: the sandbox proxy does TLS
# termination and re-signs traffic with its own CA at
# /etc/openshell-tls/ca-bundle.pem, but does not auto-configure
# git/curl/pip to trust it. Set the env vars at image level so
# every tool picks up the proxy CA without per-agent env files.
# Remove after upstream fixes CA propagation.
#
# These must be set AFTER all RUN steps — the CA file only exists at
# runtime inside the sandbox, not during CI builds.
ENV GIT_SSL_CAINFO="/etc/openshell-tls/ca-bundle.pem" \
    SSL_CERT_FILE="/etc/openshell-tls/ca-bundle.pem" \
    REQUESTS_CA_BUNDLE="/etc/openshell-tls/ca-bundle.pem" \
    CURL_CA_BUNDLE="/etc/openshell-tls/ca-bundle.pem" \
    NODE_EXTRA_CA_CERTS="/etc/openshell-tls/ca-bundle.pem"

# Switch back to the sandbox user.
USER sandbox
